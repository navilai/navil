# ── Clerk Authentication ──────────────────────────────────────────────────────
# Required for multi-user auth on navil.ai.
# Get these from https://dashboard.clerk.com → Your App → API Keys.

# Backend secret key (runtime variable in Railway)
CLERK_SECRET_KEY=your-clerk-secret-key-here

# JWT issuer URL (runtime variable in Railway)
# Found in Clerk dashboard → Configure → JWT Templates → Default template → Issuer
CLERK_ISSUER_URL=https://your-subdomain.clerk.accounts.dev

# Frontend publishable key — baked into the JS bundle at build time.
# Set this as a BUILD VARIABLE in Railway (not a runtime variable).
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Defaults to "*" when unset (fine for local dev; tighten for production).
ALLOWED_ORIGINS=https://navil.ai,https://www.navil.ai

# ── LLM Features (optional) ──────────────────────────────────────────────────
# Set the key for your preferred provider to enable AI analysis in the dashboard.
# Users can also supply their own key (BYOK) in Settings → LLM.
# ANTHROPIC_API_KEY=your-anthropic-key-here
# OPENAI_API_KEY=your-openai-key-here
# GEMINI_API_KEY=your-gemini-key-here

# ── Server (Railway sets PORT automatically — no need to override) ────────────
# PORT=8484

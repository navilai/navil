# Dashboard Environment Variables
# Copy to .env.local for local development, or set in Vercel for deployments

# Clerk authentication (get from dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# API backend URL
# Production: https://api.navil.ai
# Staging: https://api.navil.ai
# Local dev: http://localhost:8484
VITE_API_BASE_URL=http://localhost:8484
